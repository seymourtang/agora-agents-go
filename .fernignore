# Specify files that shouldn't be modified by Fern
core/request_option_custom.go
option/request_option_custom.go
tests/
changelog.md

# Wrapper layer - custom code that should not be overwritten
agentkit/
agents/start_map.go

# Documentation - managed manually, not generated by Fern
docs/
README.md
reference.md

# CI/release automation is managed manually
.github/workflows/

# Build tooling - managed manually, not generated by Fern
scripts/

# Dependency manifests are managed manually
go.mod
go.sum
.fern/replay.lock
.fern/replay.yml
.gitattributes
